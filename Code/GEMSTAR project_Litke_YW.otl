logistic dem_flag i.FluvMal age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.CPZ age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.Lamot age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.NorHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.Others_Fluox_ProHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd,or

//model 3 drug + demographics + all comorbidities (no RA) 
