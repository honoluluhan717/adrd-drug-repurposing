H="table shells "

use "${intpath}/covariates.dta",clear 

merge m:1 bene_id using "${intpath}/working_data.dta", nogen

//recode comorbidities
 
recode hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis (.=0)

//recode tri race 
tab rti_race_cd
gen race_recode=rti_race_cd
destring race_recode,replace
recode race_recode (0=4)(1=1)(2=2)(3=4)(4=4)(5=3)(6=4)
label define race_recode 1 "non-Hispanic White" 2 "non-Hispanic Black" 3 "Hispanic" 4 "Others"
label values race_recode race_recode

tab race_recode

//recode dem flags 
recode alzeimers_flag (.=1)
recode dem_flag (.=1)
recode dem_risk_flag (.=1)

tab alzeimers_flag
tab dem_flag
tab dem_risk_flag

destring sex_ident_cd,replace

tab drug_name_regroup

gen everdrug=drug_name_regroup!=.
tab everdrug

//exclude snf stay less than 100 days 
tab snf_lessthan100
drop if snf_lessthan100==1


//sample size 
sum age_at_end_ref_yr race_recode sex_ident_cd hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis

tabulate stroke everdrug, chi2 col

//create dummy categories for drug 
gen AmiHyd1=drug_name_regroup==1
gen FluvMal=drug_name_regroup==2
gen CPZ=drug_name_regroup==3
gen Lamot=drug_name_regroup==4
gen NorHyd=drug_name_regroup==5
gen Others_Fluox_ProHyd=drug_name_regroup==6

log using "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\table shells all models.smcl",replace 

//table 1 
sum age 
tab race_recode 
tab sex_ident_cd
tab dem_flag
tab hypertension 
tab diabetes 
tab stroke 
tab heart 
tab depressive 
tab tbi 
tab smoking 
tab psychosis2 
tab rheumatoid_arthritis

ttest age_at_end_ref_yr, by(everdrug)
tab race_recode everdrug,chi2
tab sex_ident_cd everdrug,chi2
tab dem_flag everdrug,chi2 
tab hypertension everdrug,chi2 
tab diabetes everdrug,chi2 
tab stroke everdrug,chi2 
tab heart everdrug,chi2 
tab depressive everdrug,chi2 
tab tbi everdrug,chi2 
tab smoking everdrug,chi2 
tab psychosis2 everdrug,chi2 
tab rheumatoid_arthritis everdrug,chi2 

tab dem_flag AmiHyd1, chi2 col
tab dem_flag FluvMal, chi2 col
tab dem_flag CPZ, chi2 col
tab dem_flag Lamot, chi2 col
tab dem_flag NorHyd, chi2 col
tab dem_flag Others_Fluox_ProHyd, chi2 col

//table 2 - see risk of people having dementia when taking drugs 
//model 1 only drugs 
logistic dem_flag i.everdrug,or
logistic dem_flag i.AmiHyd1,or
logistic dem_flag i.FluvMal,or
logistic dem_flag i.CPZ,or
logistic dem_flag i.Lamot,or
logistic dem_flag i.NorHyd,or
logistic dem_flag i.Others_Fluox_ProHyd,or

//model 2 drug + demographics 
logistic dem_flag i.everdrug age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.AmiHyd1 age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.FluvMal age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.CPZ age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.Lamot age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.NorHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic dem_flag i.Others_Fluox_ProHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd,or

//model 3 drug + demographics + all comorbidities (no RA) 
logistic dem_flag i.everdrug age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic dem_flag i.AmiHyd1 age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic dem_flag i.FluvMal age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic dem_flag i.CPZ age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic dem_flag i.Lamot age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic dem_flag i.NorHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic dem_flag i.Others_Fluox_ProHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or

//table 4 - drug + demographics + all comorbidities with RA 
logistic dem_flag i.everdrug age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2 i.rheumatoid_arthritis,or
logistic dem_flag i.AmiHyd1 age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2 i.rheumatoid_arthritis,or
logistic dem_flag i.FluvMal age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2 i.rheumatoid_arthritis,or
logistic dem_flag i.CPZ age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2 i.rheumatoid_arthritis,or
logistic dem_flag i.Lamot age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2 i.rheumatoid_arthritis,or
logistic dem_flag i.NorHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2 i.rheumatoid_arthritis,or
logistic dem_flag i.Others_Fluox_ProHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2 i.rheumatoid_arthritis,or


//Table 3 - see if people have stroke has a higher risk of dementia 
//model 1 only drugs 
logistic stroke i.everdrug,or
logistic stroke i.AmiHyd1,or
logistic stroke i.FluvMal,or
logistic stroke i.CPZ,or
logistic stroke i.Lamot,or
logistic stroke i.NorHyd,or
logistic stroke i.Others_Fluox_ProHyd,or

//model 2 drug + demographics 
logistic stroke i.everdrug age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic stroke i.AmiHyd1 age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic stroke i.FluvMal age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic stroke i.CPZ age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic stroke i.Lamot age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic stroke i.NorHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic stroke i.Others_Fluox_ProHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd,or

//model 3 drug + demographics + comorbidities 
logistic stroke i.everdrug age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.diabetes i.smoking,or
logistic stroke i.AmiHyd1 age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.diabetes i.smoking,or
logistic stroke i.FluvMal age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.diabetes i.smoking,or
logistic stroke i.CPZ age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.diabetes i.smoking,or
logistic stroke i.Lamot age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.diabetes i.smoking,or
logistic stroke i.NorHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.diabetes i.smoking,or
logistic stroke i.Others_Fluox_ProHyd age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.diabetes i.smoking,or


