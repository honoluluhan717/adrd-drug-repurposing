H="Bynum equation for Lauren's code"
use "${intpath}/partd.dta", clear 

gen ndc=substr(prod_srvc_id, 1, strlen(prod_srvc_id)-2)
keep bene_id ndc

joinby ndc using "${intpath}/drug_name.dta"

duplicates report bene_id drug_name
return list 
duplicates drop bene_id drug_name, force 

drop ndc

save "${intpath}/drug_name_complete.dta", replace 


use "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\new_bynum\bene_ADRD_all_sources_2019", clear 
rename *, lower
merge 1:m bene_id using "${intpath}/drug_name_complete.dta", nogen

//create analytic groups 

tab drug_name

gen drug_name_regroup = 6 if drug_name == "Fluox" | drug_name== "ProHyd"
replace drug_name_regroup = 1 if drug_name == "AmiHyd1"
replace drug_name_regroup = 2 if drug_name == "FluvMal"
replace drug_name_regroup = 3 if drug_name == "CPZ"
replace drug_name_regroup = 4 if drug_name == "Lamot"
replace drug_name_regroup = 5 if drug_name == "NorHyd"
by bene_id, sort: replace drug_name_regroup = 7 if _N>1
duplicates drop bene_id, force

label define drug_name_regroup 0 "no drug taken" 1 "AmiHyd1" 2 "FluvMal" 3 "CPZ" 4 "Lamot" 5 "NorHyd" 6 "Others (Fluox + ProHyd)" 7 "take more than one drug"
label values drug_name_regroup drug_name_regroup

tab drug_name_regroup,m
recode drug_name_regroup (.=0)

gen everdrug=drug_name_regroup!=0
tab everdrug

//replace adrd missing to 0

replace adrd_dx=0 if adrd_dx==.

tab adrd_dx drug_name_regroup

logistic adrd_dx i.drug_name_regroup,or

save "${intpath}/newBynum.dta", replace 

//merge to covariates 
use "${intpath}/covariates.dta",clear 

//recode comorbidities

tab hypertension
tab diabetes
tab stroke
tab heart
tab depressive
tab tbi
tab smoking
tab psychosis2
tab rheumatoid_arthritis

merge 1:1 bene_id using "${intpath}/newBynum.dta"

save "${intpath}/newBynum2.dta",replace 

//merge to medpar to get snf stay less than 100 & mbsf 
use "${datapath}\medpar\medpar_claims.dta", clear 
rename *,lower
keep bene_id dgns_*_cd ss_ls_snf_ind_cd los_day_cnt
drop dgns_e_* dgns_poa_cd

gen snf_lessthan100=ss_ls_snf_ind_cd=="N" & los_day_cnt<100

keep bene_id snf_lessthan100

//drop duplicates 
sort bene_id snf_lessthan100
quietly by bene_id snf_lessthan100: gen dup=cond(_N==1, 0, _n)
drop if dup>1
drop if dup>0
drop dup

drop if snf_lessthan100==0
duplicates report bene_id

save "${intpath}/medpar_new.dta",replace

preserve 
use "${datapath}\mbsf_abcd\mbsf_claims.dta",clear 
keep bene_id age_at_end_ref_yr rti_race_cd sex_ident_cd

tempfile mbsf
save `mbsf'

restore


merge m:1 bene_id using `mbsf', nogen

merge m:1 bene_id using "${intpath}/newBynum2.dta",nogen 

recode snf_lessthan100 (.=0)
recode adrd_dx (.=0)
recode hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis (.=0)
recode drug_name_regroup everdrug (.=0)

destring sex_ident_cd, replace
destring rti_race_cd, replace

save "${intpath}/working_data_newBynum.dta",replace










H="Avi's table5"
log using "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\Avi table5.smcl",replace 

use "${intpath}/working_data_newBynum.dta",clear 

//only keep snf stay greater than 100 days 
drop if snf_lessthan100==1

//recode tri race 
gen race_recode=rti_race_cd
destring race_recode,replace
recode race_recode (0=4)(1=1)(2=2)(3=4)(4=4)(5=3)(6=4)
label define race_recode 1 "non-Hispanic White" 2 "non-Hispanic Black" 3 "Hispanic" 4 "Others"
label values race_recode race_recode


//create RA med flag 
//everdrug flag 
gen ra_anydrug_flag=.

replace ra_anydrug_flag=0 if rheumatoid_arthritis==0 & everdrug==0
replace ra_anydrug_flag=1 if rheumatoid_arthritis==1 & everdrug==1
replace ra_anydrug_flag=2 if rheumatoid_arthritis==1 & everdrug==0
replace ra_anydrug_flag=3 if rheumatoid_arthritis==0 & everdrug==1

label define ra_anydrug_flag 0 "no RA no drug" 1 "RA+drug" 2 "RA+no drug" 3 "no RA+drug" 
label values ra_anydrug_flag ra_anydrug_flag

tab ra_anydrug_flag,m

//AmiHyd1
gen ra_AmiHyd1_flag=.

replace ra_AmiHyd1_flag=0 if rheumatoid_arthritis==0 & drug_name_regroup!=1
replace ra_AmiHyd1_flag=1 if rheumatoid_arthritis==1 & drug_name_regroup==1
replace ra_AmiHyd1_flag=2 if rheumatoid_arthritis==1 & drug_name_regroup!=1
replace ra_AmiHyd1_flag=3 if rheumatoid_arthritis==0 & drug_name_regroup==1

label define ra_AmiHyd1_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_AmiHyd1_flag ra_AmiHyd1_flag

tab ra_AmiHyd1_flag,m

//FluvMal
gen ra_FluvMal_flag=.

replace ra_FluvMal_flag=0 if rheumatoid_arthritis==0 & drug_name_regroup!=2
replace ra_FluvMal_flag=1 if rheumatoid_arthritis==1 & drug_name_regroup==2
replace ra_FluvMal_flag=2 if rheumatoid_arthritis==1 & drug_name_regroup!=2
replace ra_FluvMal_flag=3 if rheumatoid_arthritis==0 & drug_name_regroup==2

label define ra_FluvMal_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_FluvMal_flag ra_FluvMal_flag

tab ra_FluvMal_flag,m


//CPZ
gen ra_CPZ_flag=.

replace ra_CPZ_flag=0 if rheumatoid_arthritis==0 & drug_name_regroup!=3
replace ra_CPZ_flag=1 if rheumatoid_arthritis==1 & drug_name_regroup==3
replace ra_CPZ_flag=2 if rheumatoid_arthritis==1 & drug_name_regroup!=3
replace ra_CPZ_flag=3 if rheumatoid_arthritis==0 & drug_name_regroup==3

label define ra_CPZ_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_CPZ_flag ra_CPZ_flag

tab ra_CPZ_flag,m


//Lamot
gen ra_Lamot_flag=.

replace ra_Lamot_flag=0 if rheumatoid_arthritis==0 & drug_name_regroup!=4
replace ra_Lamot_flag=1 if rheumatoid_arthritis==1 & drug_name_regroup==4
replace ra_Lamot_flag=2 if rheumatoid_arthritis==1 & drug_name_regroup!=4
replace ra_Lamot_flag=3 if rheumatoid_arthritis==0 & drug_name_regroup==4

label define ra_Lamot_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_Lamot_flag ra_Lamot_flag

tab ra_Lamot_flag,m


//NorHyd
gen ra_NorHyd_flag=.

replace ra_NorHyd_flag=0 if rheumatoid_arthritis==0 & drug_name_regroup!=5
replace ra_NorHyd_flag=1 if rheumatoid_arthritis==1 & drug_name_regroup==5
replace ra_NorHyd_flag=2 if rheumatoid_arthritis==1 & drug_name_regroup!=5
replace ra_NorHyd_flag=3 if rheumatoid_arthritis==0 & drug_name_regroup==5

label define ra_NorHyd_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_NorHyd_flag ra_NorHyd_flag

tab ra_NorHyd_flag,m


//FluxProHyd
gen ra_FluxProHyd_flag=.

replace ra_FluxProHyd_flag=0 if rheumatoid_arthritis==0 & drug_name_regroup!=6
replace ra_FluxProHyd_flag=1 if rheumatoid_arthritis==1 & drug_name_regroup==6
replace ra_FluxProHyd_flag=2 if rheumatoid_arthritis==1 & drug_name_regroup!=6
replace ra_FluxProHyd_flag=3 if rheumatoid_arthritis==0 & drug_name_regroup==6

label define ra_FluxProHyd_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_FluxProHyd_flag ra_FluxProHyd_flag

tab ra_FluxProHyd_flag,m

//bivariate analyses 
preserve 

keep if rheumatoid_arthritis==1
tab stroke adrd_dx,chi2 row
tab hypertension adrd_dx,chi2 row
tab diabetes adrd_dx,chi2 row
tab heart adrd_dx,chi2 row
tab depressive adrd_dx,chi2 row
tab tbi adrd_dx,chi2 row
tab smoking adrd_dx,chi2 row
tab psychosis2 adrd_dx,chi2 row

restore

//Table 5 models 
//model1 
logistic adrd_dx i.ra_anydrug_flag,or
logistic adrd_dx i.ra_AmiHyd1_flag,or
logistic adrd_dx i.ra_FluvMal_flag,or
logistic adrd_dx i.ra_CPZ_flag,or
logistic adrd_dx i.ra_Lamot_flag,or
logistic adrd_dx i.ra_NorHyd_flag,or
logistic adrd_dx i.ra_FluxProHyd_flag,or

//model2
logistic adrd_dx i.ra_anydrug_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_AmiHyd1_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_FluvMal_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_CPZ_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_Lamot_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_NorHyd_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_FluxProHyd_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd,or


//model3 
logistic adrd_dx i.ra_anydrug_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_AmiHyd1_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_FluvMal_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_CPZ_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_Lamot_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_NorHyd_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_FluxProHyd_flag age_at_end_ref_yr i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or


translate "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\Avi table5.smcl" "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\Avi table5.pdf"

log close 











