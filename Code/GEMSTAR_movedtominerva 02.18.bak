H="create inflammatory disease flag "
//append and merge all medicare data
//carrier
use "${datapath}/carrier_claims/carrier_claims.dta", clear 
	rename *,lower
	keep bene_id icd_dgns_cd*
	gen inflamm_disease_flag=0
	
		forvalues i=1/12 {
			replace inflamm_disease_flag=1 if inlist(substr(icd_dgns_cd`i',1,3),"L20") | inlist(substr(icd_dgns_cd`i',1,3),"L30") | inlist(substr(icd_dgns_cd`i',1,3),"K50") | inlist(substr(icd_dgns_cd`i',1,3),"K51") | inlist(substr(icd_dgns_cd`i',1,3),"K52") | inlist(substr(icd_dgns_cd`i',1,3),"J45") | inlist(substr(icd_dgns_cd`i',1,3),"G35") 
			replace inflamm_disease_flag=1 if inlist(substr(icd_dgns_cd`i',1,3),"M35") | inlist(substr(icd_dgns_cd`i',1,3),"M05") | inlist(substr(icd_dgns_cd`i',1,4),"M061") | inlist(substr(icd_dgns_cd`i',1,3),"M45") | inlist(substr(icd_dgns_cd`i',1,3),"M46") | inlist(substr(icd_dgns_cd`i',1,4),"L405") | inlist(substr(icd_dgns_cd`i',1,3),"M07") | inlist(substr(icd_dgns_cd`i',1,4),"M021") | inlist(substr(icd_dgns_cd`i',1,4),"M023") | inlist(substr(icd_dgns_cd`i',1,4),"M028") | inlist(substr(icd_dgns_cd`i',1,4),"M029") | inlist(substr(icd_dgns_cd`i',1,3),"M32") | inlist(substr(icd_dgns_cd`i',1,3),"M33") | inlist(substr(icd_dgns_cd`i',1,3),"M34") 
			replace inflamm_disease_flag=1 if inlist(substr(icd_dgns_cd`i',1,4),"M352") | inlist(substr(icd_dgns_cd`i',1,4),"I776") | inlist(substr(icd_dgns_cd`i',1,4),"M312") | inlist(substr(icd_dgns_cd`i',1,3),"M30") | inlist(substr(icd_dgns_cd`i',1,4),"M350") | inlist(substr(icd_dgns_cd`i',1,3),"L40")
		}
		

keep bene_id inflamm_disease_flag
save "${intpath}/inflamm_disease_flag_carrier.dta",replace


//hospice, outpatient 
foreach x in hospice outpt {
	use "${datapath}/`x'_claims/`x'_claims.dta", clear 
		rename *,lower
	keep bene_id icd_dgns_cd*
	gen inflamm_disease_flag=0
	
		forvalues i=1/12 {
			replace inflamm_disease_flag=1 if inlist(substr(icd_dgns_cd`i',1,3),"L20") | inlist(substr(icd_dgns_cd`i',1,3),"L30") | inlist(substr(icd_dgns_cd`i',1,3),"K50") | inlist(substr(icd_dgns_cd`i',1,3),"K51") | inlist(substr(icd_dgns_cd`i',1,3),"K52") | inlist(substr(icd_dgns_cd`i',1,3),"J45") | inlist(substr(icd_dgns_cd`i',1,3),"G35") 
			replace inflamm_disease_flag=1 if inlist(substr(icd_dgns_cd`i',1,3),"M35") | inlist(substr(icd_dgns_cd`i',1,3),"M05") | inlist(substr(icd_dgns_cd`i',1,4),"M061") | inlist(substr(icd_dgns_cd`i',1,3),"M45") | inlist(substr(icd_dgns_cd`i',1,3),"M46") | inlist(substr(icd_dgns_cd`i',1,4),"L405") | inlist(substr(icd_dgns_cd`i',1,3),"M07") | inlist(substr(icd_dgns_cd`i',1,4),"M021") | inlist(substr(icd_dgns_cd`i',1,4),"M023") | inlist(substr(icd_dgns_cd`i',1,4),"M028") | inlist(substr(icd_dgns_cd`i',1,4),"M029") | inlist(substr(icd_dgns_cd`i',1,3),"M32") | inlist(substr(icd_dgns_cd`i',1,3),"M33") | inlist(substr(icd_dgns_cd`i',1,3),"M34") 
			replace inflamm_disease_flag=1 if inlist(substr(icd_dgns_cd`i',1,4),"M352") | inlist(substr(icd_dgns_cd`i',1,4),"I776") | inlist(substr(icd_dgns_cd`i',1,4),"M312") | inlist(substr(icd_dgns_cd`i',1,3),"M30") | inlist(substr(icd_dgns_cd`i',1,4),"M350") | inlist(substr(icd_dgns_cd`i',1,3),"L40")
		}
		

keep bene_id inflamm_disease_flag
save "${intpath}/inflamm_disease_flag_`x'.dta",replace
}


