H="..........after moving to Minerva..........."


H="change or to rr"
log using "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/table 3 with 6 models rr 12.23.smcl",replace 

use "${intpath}/new working data08.29.dta",clear 

//6 models in Table 3 
foreach a in CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd everdrug{
	//Model 1- Controlling for age 
	glm adrd_dx age_at_end_ref_yr i.`a', fam(bin) link(log) nolog eform

	//Model 2- With Demographics (age, sex, race/ethnicity) 
	glm adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd, fam(bin) link(log) nolog eform

	//Model 3- With Demographics and behavioral (smoking) risk factors in table 1 
	glm adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking, fam(bin) link(log) nolog eform

	//Model 4- With Demographics, and behavioral (smoking), TBI risk factors in table 1 
	glm adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi, fam(bin) link(log) nolog eform

	//Model 5- With Demographics, and behavioral (smoking), TBI, cardiometabolic risk factors in table 1 
	glm adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.stroke i.hypertension i.diabetes i.heart, fam(bin) link(log) nolog eform

	//Model 6- With Demographics, and behavioral (smoking), TBI, cardiometabolic and psychiatric risk factors in table 1  
	glm adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.stroke i.hypertension i.diabetes i.heart 	i.depressive i.psychosis2, fam(bin) link(log) nolog eform
}

log close 

translate "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/table 3 with 6 models rr 12.23.smcl" "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/table 3 with 6 models rr 12.23.pdf"





H="create ani-inflammatory drug flag "
use "/sc/cmsdata/drugsAD/PEPPER 2019/Raw Data/pde_char/pde_converted.dta",clear 

rename*,lower

//1. NON-SELECTIVE NSAIDS (17 DRUGS) 
gen non_selec_nsaids=ustrpos(gnn, "DICLOFENAC") | ustrpos(gnn, "DIFLUNISAL") | ustrpos(gnn, "ETODOLAC") | ustrpos(gnn, "FENOPROFEN") | ustrpos(gnn, "FLURBIPROFEN") | ustrpos(gnn, "IBUPROFEN") | ustrpos(gnn, "INDOMETHACIN") | ustrpos(gnn, "KETOPROFEN") | ustrpos(gnn, "KETOROLAC") | ustrpos(gnn, "MEFENAMIC ACID") | ustrpos(gnn, "MELOXICAM") | ustrpos(gnn, "NABUMETONE") | ustrpos(gnn, "NAPROXEN") | ustrpos(gnn, "OXAPROZIN") | ustrpos(gnn, "PIROXICAM") | ustrpos(gnn, "SULINDAC") | ustrpos(gnn, "TOLMETIN")

//2. COX-2 SELECTIVE NSAIDS (1 DRUG) 

gen cox2_selec_nsaids=ustrpos(gnn, "CELECOXIB")

//3. CORTICOSTEROIDS: (27 DRUGS) 

gen corticosteroids=0 

local druglist "BUDESONIDE BECLOMETHASONE BETAMETHASONE CELESTONE CUTIVATE DECADRON DELTASONE DEPO-MEDROL DEXAMETHASONE DIPROLENE DIPROSONE ENTOCORT EC FLONASE FLOVENT FLUDROCORTISONE KENALOG MEDROL MEGACE MEGESTROL ACETATE METHYLPREDNISOLONE ORASONE PREDNISOLONE PREDNISONE RHINOCORT SOLU-MEDROL OR SOLUMEDROL TRIAMCINOLONE ACETONIDE PULMICORT BUDESONIDE"

foreach drug in `druglist' {
    replace corticosteroids = 1 if ustrpos(gnn, "`drug'") > 0
}

//4. DISEASE MODIFYING ANTI RHEUMATIC DRUG DMARD (19 DRUGS) 

gen anti_theumatic=0

local druglist1 "SULFASALAZINE MESALAZINE LEFLUNOMIDE DEUCRAVACITINIB APREMILAST ABATACEPT BIMEKIZUMAB IXEKIZUMAB RITUXIMAB TOCILIZUMAB SARILUMAB ANAKINRA USTEKINUMAB SECUKINUMAB BELIMUMAB LEFLUNOMIDE GUSELKUMAB  RIZANKIZUMAB TILDRAKIZUMAB DUPILUMAB"

foreach drug in `druglist1' {
    replace anti_theumatic = 1 if ustrpos(gnn, "`drug'") > 0
}

//5. TARGETED DMARD (1 DRUG)

gen targeted_dmard=ustrpos(gnn,"JAK 1/2/3 INHIBITOR") | ustrpos(gnn,"TOFACITINIB") | ustrpos(gnn,"ABROCITINIB") | ustrpos(gnn,"BARICITINIB") | ustrpos(gnn,"FILGOTINIB") | ustrpos(gnn,"UPADACITINIB")

//6. OTHER (4 DRUGS) 

gen other_drug=ustrpos(gnn, "CICLOSPORIN") | ustrpos(gnn,"CYCLOSPORIN") | ustrpos(gnn,"AZATHIOPRINE") | ustrpos(gnn,"TACROLIMUS") | ustrpos(gnn, "SIROLIMUS") | ustrpos(gnn, "METHOTREXATE") | ustrpos(gnn, "HYDROXYCHLOROQUINE") 

//7. IFN (2 DRUGS) 

gen inf_drug=ustrpos(gnn,"PEGINTERFERON") | ustrpos(gnn,"INTERFERON BETA") | ustrpos(gnn,"ANIFROLUMAB")


//8. ANT TNF (7 DRUGS) 

gen ant_tnf=ustrpos(gnn, "ADALIMUMAB") | ustrpos(gnn,"CERTOLIZUMAB") | ustrpos(gnn,"ETANERCEPT") | ustrpos(gnn,"GOLIMUMAB") | ustrpos(gnn, "INFLIXIMAB") | ustrpos(gnn,"ANTI INTEGRIN") | ustrpos(gnn, "VEDOLIZUMAB")

//9. overall anti-inflammatory drug list 
gen anti_inflammatory_drug=0

replace anti_inflammatory_drug=1 if non_selec_nsaids==1 | cox2_selec_nsaids==1 | corticosteroids==1 | anti_theumatic==1 | targeted_dmard==1 | other_drug==1 | inf_drug==1 | ant_tnf==1 

tab anti_inflammatory_drug

save "/sc/cmsdata/drugsAD/PEPPER 2019/Final Data/pde_anti_inflammatory_drug.dta",replace





H="merge to previous data "
use "/sc/cmsdata/drugsAD/PEPPER 2019/Final Data/pde_anti_inflammatory_drug.dta",clear 

rename*,lower

keep bene_id non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf

foreach x in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf {
	by bene_id,sort:egen a=max(`x')
    	replace `x'=a
	drop a
}

duplicates drop

egen ever_anti_inflamm_drug=rowmax(non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf)

foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf {
    replace ever_anti_inflamm_drug = 0 if missing(`var')
}

save "${intpath}/anti_inflamm_drug.dta", replace 

use "${intpath}/anti_inflamm_drug.dta",clear 
merge 1:m bene_id using "${intpath}/new working data08.29.dta"



keep if _merge==3 
drop _merge

save "${intpath}/working data with anti-inflamm-drugs 1.27.25.dta",replace

H="analyses on anti-inflammatory drugs"

log using "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables1&3 1.30.25.smcl",replace 

use "${intpath}/working data with anti-inflamm-drugs 1.27.25.dta",clear 

//table1 - overall 
tab ever_anti_inflamm_drug

sum age_at_end_ref_yr
tab race_recode
tab sex_ident_cd

tab adrd_dx 

foreach var in smoking tbi diabetes hypertension stroke heart depressive psychosis2 {
	tab `var'
}

foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	tab `var'
}

//table1 - by group 
ttest age_at_end_ref_yr,by(ever_anti_inflamm_drug)

foreach var in race_recode sex_ident_cd adrd_dx smoking tbi diabetes hypertension stroke heart depressive psychosis2 {
	tab `var' ever_anti_inflamm_drug,chi2 row col 
}

//table3 - model1 

foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logistic adrd_dx age_at_end_ref_yr i.`var',or
}

//table3 - model2 
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd `var',or
}

//table3 - model3
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking `var',or
}

//table3 - model4
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi `var',or
}

//table3 - model5
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.diabetes i.hypertension i.stroke i.heart `var',or
}

//table3 - model6
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.diabetes i.hypertension i.stroke i.heart i.depressive i.psychosis2 `var',or
}


translate "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables1&3 1.30.25.smcl" "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables1&3 1.30.25.pdf"

