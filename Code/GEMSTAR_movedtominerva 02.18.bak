//medpar 
use "${datapath}/medpar/medpar_claims.dta", clear 
rename *,lower
keep bene_id dgns_*_cd
drop dgns_e_* dgns_poa_cd

gen inflamm_disease_flag=0

forvalues i=1/25 {
	replace inflamm_disease_flag=1 if inlist(substr(dgns_`i'_cd,1,3),"L20") | inlist(substr(dgns_`i'_cd,1,3),"L30") | inlist(substr(dgns_`i'_cd,1,3),"K50") | inlist(substr(dgns_`i'_cd,1,3),"K51") | inlist(substr(dgns_`i'_cd,1,3),"K52") | inlist(substr(dgns_`i'_cd,1,3),"J45") | inlist(substr(dgns_`i'_cd,1,3),"G35") | inlist(substr(dgns_`i'_cd,1,3),"M35") | inlist(substr(dgns_`i'_cd,1,3),"M05") | inlist(substr(dgns_`i'_cd,1,4),"M061") | inlist(substr(dgns_`i'_cd,1,3),"M45") | inlist(substr(dgns_`i'_cd,1,3),"M46") | inlist(substr(dgns_`i'_cd,1,4),"L405") | inlist(substr(dgns_`i'_cd,1,3),"M07") | inlist(substr(dgns_`i'_cd,1,4),"M021") | inlist(substr(dgns_`i'_cd,1,4),"M023") | inlist(substr(dgns_`i'_cd,1,4),"M028") | inlist(substr(dgns_`i'_cd,1,4),"M32") | inlist(substr(dgns_`i'_cd,1,3),"M33") | inlist(substr(dgns_`i'_cd,1,3),"M34") | inlist(substr(dgns_`i'_cd,1,4),"M352") | inlist(substr(dgns_`i'_cd,1,4),"I776") | inlist(substr(dgns_`i'_cd,1,4),"M312") | inlist(substr(dgns_`i'_cd,1,3),"M30") | inlist(substr(dgns_`i'_cd,1,4),"M350") | inlist(substr(dgns_`i'_cd,1,3),"L40") 
			
}

keep bene_id inflamm_disease_flag

save "${intpath}/inflamm_disease_flag_medpar.dta",replace




//merge all data 
use "${intpath}/inflamm_disease_flag_carrier.dta",clear 
append using "${intpath}/inflamm_disease_flag_hospice.dta"
append using "${intpath}/inflamm_disease_flag_outpt.dta"
append using "${intpath}/inflamm_disease_flag_medpar.dta"

//drop duplicates 
sort bene_id
foreach x in inflamm_disease_flag {
	by bene_id: egen a=max(`x')
	replace `x'=a
	drop a 
}

duplicates drop

save "${intpath}/inflamm_disease_flag.dta",replace 





H="merge to previous data "
use "${intpath}/working data with anti-inflamm-drugs 1.27.25.dta",clear 

merge 1:m bene_id using "${intpath}/inflamm_disease_flag.dta"

drop if _merge==2
drop _merge

replace ever_anti_inflamm_drug=0 if missing(ever_anti_inflamm_drug)

save "${intpath}/all merged data 02.18.25.dta",replace

H="all tables with margins to get  irr "
log using "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables1&3irr 02.18.25.smcl",replace 

use "${intpath}/all merged data 02.18.25.dta",clear 

//table1 - overall 
tab ever_anti_inflamm_drug

replace inflamm_disease_flag=0 if missing(inflamm_disease_flag)
tab inflamm_disease_flag

sum age_at_end_ref_yr
tab race_recode,m
tab sex_ident_cd,m

tab adrd_dx,m

foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	tab `var'
}

//table1 - by group 
ttest age_at_end_ref_yr,by(ever_anti_inflamm_drug)

foreach var in race_recode sex_ident_cd adrd_dx smoking tbi diabetes hypertension stroke heart depressive psychosis2 {
	tab `var' ever_anti_inflamm_drug,chi2 row col 
}

//table3 - model1 

foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logit adrd_dx age_at_end_ref_yr i.`var'
	margins, dydx(i.`var') post 
	nlcom (exp(_b[1.`var']))
}

//table3 - model2 
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logit adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.`var'
	margins, dydx(i.`var') post 
	nlcom (exp(_b[1.`var']))
}

//table3 - model3
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logit adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.`var'
	margins, dydx(i.`var') post 
	nlcom (exp(_b[1.`var']))
}

//table3 - model4
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logit adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.`var'
	margins, dydx(i.`var') post 
	nlcom (exp(_b[1.`var']))
}

//table3 - model5
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logit adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.diabetes i.hypertension i.stroke i.heart i.`var'
	margins, dydx(i.`var') post 
	nlcom (exp(_b[1.`var']))
}

//table3 - model6
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logit adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.diabetes i.hypertension i.stroke i.heart i.depressive i.psychosis2 i.`var'
	margins, dydx(i.`var') post 
	nlcom (exp(_b[1.`var']))
}

//table3 - model7
foreach var in non_selec_nsaids cox2_selec_nsaids corticosteroids anti_theumatic targeted_dmard other_drug inf_drug ant_tnf ever_anti_inflamm_drug {
	logit adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.diabetes i.hypertension i.stroke i.heart i.depressive i.psychosis2 i.inflamm_disease_flag i.`var'
	margins, dydx(i.`var') post 
	nlcom (exp(_b[1.`var']))
}

translate "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables1&3irr 02.18.25.smcl" "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables1&3irr 02.18.25.pdf"

log close

H="ra patients 10/1/25"
log using "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables ra pts 10.1.25.smcl",replace 

use "/sc/cmsdata/drugsAD/PEPPER 2019/Int Data/all merged data 02.18.25.dta",clear 

gen byte anti_inflamm_ever_rheum_flag = ///
    (anti_theumatic == 1 | targeted_dmard == 1 | other_drug == 1 | inf_drug == 1 | ant_tnf == 1)
    
replace anti_inflamm_ever_rheum_flag = 0 if missing(anti_inflamm_ever_rheum_flag)

tab  anti_inflamm_ever_rheum_flag,m

//supplemental table 
tab rheumatoid_arthritis

tab rheumatoid_arthritis adrd_dx,chi2 

keep if rheumatoid_arthritis==1 

//table1 
sum age_at_end_ref_yr
tab race_recode
tab sex_ident_cd
tab adrd_dx 

foreach var in diabetes hypertension stroke depressive heart tbi smoking psychosis2 {
	tab `var',m
}

foreach var in diabetes hypertension stroke depressive heart tbi smoking psychosis2 {
	tab `var' anti_inflamm_ever_rheum_flag,m
}

//table2 
//model1 
logistic adrd_dx age_at_end_ref_yr i.anti_theumatic i.targeted_dmard i.ant_tnf i.anti_inflamm_ever_rheum_flag

//model2
logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.anti_theumatic i.targeted_dmard i.ant_tnf i.anti_inflamm_ever_rheum_flag

//model3
logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.anti_theumatic i.targeted_dmard i.ant_tnf i.anti_inflamm_ever_rheum_flag

//model4
logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.anti_theumatic i.targeted_dmard i.ant_tnf i.anti_inflamm_ever_rheum_flag

//model5
logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.heart i.anti_theumatic i.targeted_dmard i.ant_tnf i.anti_inflamm_ever_rheum_flag

//model6
logistic adrd_dx age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.heart i.psychosis2 i.anti_theumatic i.targeted_dmard i.ant_tnf i.anti_inflamm_ever_rheum_flag


translate "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables ra pts 10.1.25.smcl" "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables ra pts 10.1.25.pdf"

log close







H="stroke outcome 10/2/25"
log using "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables stroke outcome 10.6.25.smcl",replace 

use "/sc/cmsdata/drugsAD/PEPPER 2019/Int Data/all merged data 02.18.25.dta",clear 

foreach var in  race_recode sex_ident_cd hypertension heart depressive tbi smoking psychosis2 diabetes CPZ PCPZ TriHyd AmiHyd PFZ ProHyd NorHyd Flup {
	tab `var' stroke
}

logistic stroke age_at_end_ref_yr i.race_recode i.sex_ident_cd i.hypertension i.heart i.depressive i.tbi i.smoking i.psychosis2 i.diabetes i.CPZ i.PCPZ i.TriHyd i.AmiHyd i.PFZ i.ProHyd i.NorHyd i.Flup


translate "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables stroke outcome 10.6.25.smcl" "/sc/cmsdata/drugsAD/PEPPER 2019/Output/in_progress/tables stroke outcome 10.6.25.pdf"

log close










