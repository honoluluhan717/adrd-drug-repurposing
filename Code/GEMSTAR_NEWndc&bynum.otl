H="get NDC codes for NorHyd"
import sas using "J:\Geriatrics\Litke_CMS\2019\Raw Data\pde_char\pde_file.sas7bdat",clear
rename*,lower

gen ndc=substr(prod_srvc_id, 1, strlen(prod_srvc_id)-2)

//8. NORTRIPTYLINE
gen NorHyd=ustrpos(gnn, "NORTRIPTYLINE")

tostring NorHyd,replace

keep if NorHyd=="1"

duplicates report ndc
bysort ndc: keep if _n==1

keep ndc
rename ndc NorHyd

export delimited using "J:\Geriatrics\Litke_CMS\2019\Final Data\NDC Part D\NorHyd_newpde.csv",replace

H="merge into one Part D drug names (skip)"

use "J:\Geriatrics\Litke_CMS\2019\Final Data\NDC part D\part d NDC codes 8 drugs.dta",clear

foreach x of varlist * {
	preserve 
	keep `x'
	rename `x' prod_srvc_id
	gen drug_name="`x'"
	save "${intpath}/`x'",replace
	restore
}

clear 

foreach y in CPZ TriHyd NorHyd PCPZ Flup AmiHyd ProHyd Flup {
	append using "${intpath}/`y'"
}

drop if prod_srvc_id==.

rename prod_srvc_id ndc 

duplicates drop ndc drug_name, force

save "${intpath}/partd_8drugnames.dta",replace

H="get snf + merge to mbsf"

//get snf stay from medpar 
use "${datapath}\medpar\medpar_claims.dta", clear 
rename *,lower
keep bene_id ss_ls_snf_ind_cd los_day_cnt

gen snf_lessthan100=ss_ls_snf_ind_cd=="N" & los_day_cnt<100

keep bene_id snf_lessthan100

duplicates drop

merge m:1 bene_id using "${datapath}\mbsf_abcd\mbsf_claims.dta", nogen


duplicates report bene_id
duplicates drop bene_id,force

keep bene_id age_at_end_ref_yr rti_race_cd sex_ident_cd snf_lessthan100

save "${intpath}/demo_data.dta",replace 


H="create drug names from part d"
import sas using "J:\Geriatrics\Litke_CMS\2019\Raw Data\pde_char\pde_file.sas7bdat",clear
rename*,lower
keep bene_id prod_srvc_id gnn

gen ndc=substr(prod_srvc_id, 1, strlen(prod_srvc_id)-2)

gen CPZ=ustrpos(gnn, "CHLORPROMAZINE")
gen PCPZ=ustrpos(gnn, "PROCHLORPERAZINE")
gen TriHyd=ustrpos(gnn, "TRIFLUOPERAZINE")
gen AmiHyd=ustrpos(gnn, "AMITRIPTYLINE")
recode AmiHyd (14=1)
gen PFZ=ustrpos(gnn, "PERPHENAZINE")
gen Flup=ustrpos(gnn, "FLUPHENAZINE")
gen ProHyd=ustrpos(gnn, "PROMETHAZINE")
gen NorHyd=ustrpos(gnn, "NORTRIPTYLINE")

gen drug_name=.
replace drug_name = 1 if CPZ==1
replace drug_name = 2 if PCPZ==1
replace drug_name = 3 if TriHyd==1
replace drug_name = 4 if AmiHyd==1
replace drug_name = 5 if PFZ==1
replace drug_name = 6 if Flup==1
replace drug_name = 7 if ProHyd==1 
replace drug_name = 8 if NorHyd==1 

gen anti_inflam=ustrpos(gnn, "DICLOFENAC") | ustrpos(gnn, "DIFLUNISAL") | ustrpos(gnn, "ETODOLAC") | ustrpos(gnn, "FENOPROFEN") | ustrpos(gnn, "FLURBIPROFEN") | ustrpos(gnn, "IBUPROFEN") | ustrpos(gnn, "INDOMETHACIN") | ustrpos(gnn, "KETOPROFEN") | ustrpos(gnn, "KETOROLAC") | ustrpos(gnn, "MEFENAMIC ACID") | ustrpos(gnn, "MELOXICAM") | ustrpos(gnn, "NABUMETONE") | ustrpos(gnn, "NAPROXEN") | ustrpos(gnn, "OXAPROZIN") | ustrpos(gnn, "PIROXICAM") | ustrpos(gnn, "SULINDAC") | ustrpos(gnn, "TOLMETIN") | ustrpos(gnn, "CELECOXIB") | ustrpos(gnn, "BUDESONIDE") | ustrpos(gnn, "BECLOMETHASONE") | ustrpos(gnn, "BETAMETHASONE") | ustrpos(gnn, "CELESTONE") | ustrpos(gnn, "CUTIVAT") | ustrpos(gnn, "DECADRON") | ustrpos(gnn, "DELTASONE") | ustrpos(gnn, "DEPO-MEDROL") | ustrpos(gnn, "DEXAMETHASONE") | ustrpos(gnn, "DIPROLENE") | ustrpos(gnn, "DIPROSONE") | ustrpos(gnn, "ENTOCORT EC") | ustrpos(gnn, "FLONASE") | ustrpos(gnn, "FLOVENT") | ustrpos(gnn, "FLUDROCORTISONE") | ustrpos(gnn, "KENALOG") | ustrpos(gnn, "MEDROL") | ustrpos(gnn, "MEGACE") | ustrpos(gnn, "MEGESTROL ACETATE") | ustrpos(gnn, "METHYLPREDNISOLONE") | ustrpos(gnn, "ORASONE") | ustrpos(gnn, "PREDNISOLONE") | ustrpos(gnn, "PREDNISONE") | ustrpos(gnn, "RHINOCORT") | ustrpos(gnn, "SOLU-MEDROL OR SOLUMEDROL") | ustrpos(gnn, "TRIAMCINOLONE ACETONIDE") | ustrpos(gnn, "PULMICOR") | ustrpos(gnn, "SULFASALAZINE") | ustrpos(gnn, "MESALAZINE") | ustrpos(gnn, "LEFLUNOMIDE") | ustrpos(gnn, "APREMILAST") | ustrpos(gnn, "ABATACEPT") | ustrpos(gnn, "BIMEKIZUMAB") | ustrpos(gnn, "IXEKIZUMAB") | ustrpos(gnn, "RITUXIMAB") | ustrpos(gnn, "TOCILIZUMAB") | ustrpos(gnn, "SARILUMAB") | ustrpos(gnn, "ANAKINRA") | ustrpos(gnn, "USTEKINUMAB") | ustrpos(gnn, "SECUKINUMAB") | ustrpos(gnn, "BELIMUMAB") | ustrpos(gnn, "LEFLUNOMIDE") | ustrpos(gnn, "GUSELKUMAB") | ustrpos(gnn, "RIZANKIZUMAB") | ustrpos(gnn, "MEGACE") | ustrpos(gnn, "MEGESTROL ACETATE") | ustrpos(gnn, "METHYLPREDNISOLONE") | ustrpos(gnn, "ORASONE") | ustrpos(gnn, "PREDNISOLONE") | ustrpos(gnn, "TILDRAKIZUMAB") | ustrpos(gnn, "DUPILUMAB") |ustrpos(gnn, "JAK 1/2/3 INHIBITOR") | ustrpos(gnn, "TOFACITINIB") | ustrpos(gnn, "CICLOSPORIN") | ustrpos(gnn, "CYCLOSPORIN") | ustrpos(gnn, "AZATHIOPRINE") | ustrpos(gnn, "TACROLIMUS") | ustrpos(gnn, "SIROLIMUS") | ustrpos(gnn, "PEGINTERFERON") | ustrpos(gnn, "INTERFERON BETA") | ustrpos(gnn, "ADALIMUMAB") | ustrpos(gnn, "CERTOLIZUMAB") | ustrpos(gnn, "ETANERCEPT") | ustrpos(gnn, "GOLIMUMAB") | ustrpos(gnn, "INFLIXIMAB") | ustrpos(gnn, "ANTI INTEGRIN ?4?7") | ustrpos(gnn, "VEDOLIZUMAB") 

drop if drug_name==.
drop gnn prod_srvc_id ndc

duplicates report bene_id drug_name
return list 

foreach x in CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd {
	by bene_id,sort:egen a=max(`x')
    	replace `x'=a
	drop a
}

drop drug_name
duplicates drop

egen everdrug=rowmax(CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd)
egen countdrug=rowtotal(CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd)

save "${intpath}/partd8drugs.dta", replace 



H="get covariates"
//append and merge all medicare data
//carrier
use "${datapath}/carrier_claims/carrier_claims.dta", clear 
	rename *,lower
	keep bene_id icd_dgns_cd*
	gen hypertension=0
	gen diabetes=0
	gen stroke=0
	gen heart=0
	gen depressive=0
	gen tbi=0
	gen smoking=0
	gen psychosis2=0
	gen rheumatoid_arthritis=0
	
		forvalues i=1/12 {
			replace hypertension=1 if inlist(substr(icd_dgns_cd`i',1,3),"I10") 
			replace diabetes=1 if inlist(substr(icd_dgns_cd`i',1,3),"E10") | inlist(substr(icd_dgns_cd`i',1,3),"E11") 
			replace stroke=1 if inlist(substr(icd_dgns_cd`i',1,3),"I63") 
			replace heart=1 if inlist(substr(icd_dgns_cd`i',1,3),"I25") | inlist(substr(icd_dgns_cd`i',1,3),"I11") 
			replace depressive=1 if inlist(substr(icd_dgns_cd`i',1,3),"F32") | inlist(substr(icd_dgns_cd`i',1,3),"F33") 
			replace tbi=1 if inlist(substr(icd_dgns_cd`i',1,3),"S02") | inlist(substr(icd_dgns_cd`i',1,3),"S06") | inlist(substr(icd_dgns_cd`i',1,3),"S07") 
			replace smoking=1 if inlist(substr(icd_dgns_cd`i',1,3),"F17") | icd_dgns_cd`i'=="Z77"
			replace psychosis2=1 if inlist(substr(icd_dgns_cd`i',1,3),"F20") | inlist(substr(icd_dgns_cd`i',1,3),"F21") | inlist(substr(icd_dgns_cd`i',1,3),"F22") | inlist(substr(icd_dgns_cd`i',1,3),"F23") | inlist(substr(icd_dgns_cd`i',1,3),"F24")
			replace psychosis2=1 if inlist(substr(icd_dgns_cd`i',1,3),"F25") | inlist(substr(icd_dgns_cd`i',1,3),"F26") | inlist(substr(icd_dgns_cd`i',1,3),"F27") | inlist(substr(icd_dgns_cd`i',1,3),"F28") | inlist(substr(icd_dgns_cd`i',1,3),"F29") | inlist(substr(icd_dgns_cd`i',1,3),"F30") 
			replace rheumatoid_arthritis=1 if inlist(substr(icd_dgns_cd`i',1,3),"M05") | inlist(substr(icd_dgns_cd`i',1,3),"M06") & !inlist(substr(icd_dgns_cd`i',1,3),"M061")
		}

keep bene_id hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis
save "${intpath}/comorbidities_carrier.dta",replace


//hospice, outpatient 
foreach x in hospice outpt {
	use "${datapath}/`x'_claims/`x'_claims.dta", clear 
	
	rename *,lower
	keep bene_id icd_dgns_cd*
	gen hypertension=0
	gen diabetes=0
	gen stroke=0
	gen heart=0
	gen depressive=0
	gen tbi=0
	gen smoking=0
	gen psychosis2=0
	gen rheumatoid_arthritis=0

		forvalues i=1/25 {
			replace hypertension=1 if inlist(substr(icd_dgns_cd`i',1,3),"I10") 
			replace diabetes=1 if inlist(substr(icd_dgns_cd`i',1,3),"E10") | inlist(substr(icd_dgns_cd`i',1,3),"E11") 
			replace stroke=1 if inlist(substr(icd_dgns_cd`i',1,3),"I63") 
			replace heart=1 if inlist(substr(icd_dgns_cd`i',1,3),"I25") | inlist(substr(icd_dgns_cd`i',1,3),"I11") 
			replace depressive=1 if inlist(substr(icd_dgns_cd`i',1,3),"F32") | inlist(substr(icd_dgns_cd`i',1,3),"F33") 
			replace tbi=1 if inlist(substr(icd_dgns_cd`i',1,3),"S02") | inlist(substr(icd_dgns_cd`i',1,3),"S06") | inlist(substr(icd_dgns_cd`i',1,3),"S07") 
			replace smoking=1 if inlist(substr(icd_dgns_cd`i',1,3),"F17") | inlist(substr(icd_dgns_cd`i',1,3),"Z77") 
			replace psychosis2=1 if inlist(substr(icd_dgns_cd`i',1,3),"F20") | inlist(substr(icd_dgns_cd`i',1,3),"F21") | inlist(substr(icd_dgns_cd`i',1,3),"F22")| inlist(substr(icd_dgns_cd`i',1,3),"F23") | inlist(substr(icd_dgns_cd`i',1,3),"F24") | inlist(substr(icd_dgns_cd`i',1,3),"F25")
			replace psychosis2=1 if	inlist(substr(icd_dgns_cd`i',1,3),"F26") | inlist(substr(icd_dgns_cd`i',1,3),"F27") | inlist(substr(icd_dgns_cd`i',1,3),"F28") | inlist(substr(icd_dgns_cd`i',1,3),"F29") | inlist(substr(icd_dgns_cd`i',1,3),"F30") 
			replace rheumatoid_arthritis=1 if inlist(substr(icd_dgns_cd`i',1,3),"M05") | inlist(substr(icd_dgns_cd`i',1,3),"M06") & !inlist(substr(icd_dgns_cd`i',1,3),"M061")
		}

keep bene_id hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis
save "${intpath}/comorbidities_`x'.dta",replace
}


//medpar 
use "${datapath}\medpar\medpar_claims.dta", clear 
rename *,lower
keep bene_id dgns_*_cd
drop dgns_e_* dgns_poa_cd

gen hypertension=0
gen diabetes=0
gen stroke=0
gen heart=0
gen depressive=0
gen tbi=0
gen smoking=0
gen psychosis2=0
gen rheumatoid_arthritis=0

forvalues i=1/25 {
	replace hypertension=1 if inlist(substr(dgns_`i'_cd,1,3),"I10") 
			replace diabetes=1 if inlist(substr(dgns_`i' _cd,1,3),"E10") | inlist(substr(dgns_`i'_cd,1,3),"E11") 
			replace stroke=1 if inlist(substr(dgns_`i'_cd,1,3),"I63") 
			replace heart=1 if inlist(substr(dgns_`i'_cd,1,3),"I25") | inlist(substr(dgns_`i'_cd,1,3),"I11") 
			replace depressive=1 if inlist(substr(dgns_`i'_cd,1,3),"F32") | inlist(substr(dgns_`i'_cd,1,3),"F33") 
			replace tbi=1 if inlist(substr(dgns_`i'_cd,1,3),"S02") | inlist(substr(dgns_`i'_cd,1,3),"S06") | inlist(substr(dgns_`i'_cd,1,3),"S07") 
			replace smoking=1 if inlist(substr(dgns_`i'_cd,1,3),"F17") | inlist(substr(dgns_`i'_cd,1,3),"Z77")
			replace psychosis2=1 if inlist(substr(dgns_`i'_cd,1,3),"F20") | inlist(substr(dgns_`i'_cd,1,3),"F21") | inlist(substr(dgns_`i'_cd,1,3),"F22")| inlist(substr(dgns_`i'_cd,1,3),"F23") | inlist(substr(dgns_`i'_cd,1,3),"F24") | inlist(substr(dgns_`i'_cd,1,3),"F25")
			replace psychosis2=1 if	inlist(substr(dgns_`i'_cd,1,3),"F26") | inlist(substr(dgns_`i'_cd,1,3),"F27") | inlist(substr(dgns_`i'_cd,1,3),"F28") | inlist(substr(dgns_`i'_cd,1,3),"F29") | inlist(substr(dgns_`i'_cd,1,3),"F30") 	
             replace rheumatoid_arthritis=1 if inlist(substr(dgns_`i'_cd,1,3),"M05") | inlist(substr(dgns_`i'_cd,1,3),"M06") & !inlist(substr(dgns_`i'_cd,1,3),"M061")
}

keep bene_id hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis

save "${intpath}/comorbidities_medpar.dta",replace

//merge all data 
use "${intpath}/comorbidities_carrier.dta",clear 
append using "${intpath}/comorbidities_hospice.dta"
append using "${intpath}/comorbidities_outpt.dta"
append using "${intpath}/comorbidities_medpar.dta"

//drop duplicates 
sort bene_id
foreach x in hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis {
	by bene_id: egen a=max(`x')
	replace `x'=a
	drop a 
}

duplicates drop

save "${intpath}/covariates.dta",replace 





H="merge new Bynum code to all data "
use "${intpath}/newBynum.dta",clear
merge 1:m bene_id using "${intpath}/covariates.dta"
drop everdrug 
drop if _merge==1 
drop _merge 

merge 1:m bene_id using "${intpath}/partd8drugs.dta",force
drop if _merge==2
drop _merge

merge m:1 bene_id using "${intpath}/demo_data.dta"

recode adrd_dx (.=0)

recode hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis (.=0)
recode CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd everdrug countdrug (.=0)

//recode tri race 
tab rti_race_cd
gen race_recode=rti_race_cd
destring race_recode,replace
recode race_recode (0=4)(1=1)(2=2)(3=4)(4=4)(5=3)(6=4)
label define race_recode 1 "non-Hispanic White" 2 "non-Hispanic Black" 3 "Hispanic" 4 "Others"
label values race_recode race_recode

//exclude snf stay less than 100 days 
tab snf_lessthan100
drop if snf_lessthan100==1

//sample size 
sum age_at_end_ref_yr race_recode sex_ident_cd hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis

sum CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd

destring sex_ident_cd,replace

save "${intpath}/new working data08.29.dta",replace 


H="log translate"
translate "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\new sample 08.28.smcl" "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\new sample 08.28.pdf"

H="table 1 & 2"
log using "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\tables1&2 09.05.smcl",replace 

use "${intpath}/new working data08.29.dta",clear 

//sample size 
sum age_at_end_ref_yr race_recode sex_ident_cd hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis
sum everdrug countdrug

//univariate 
sum age_at_end_ref_yr
tab race_recode 
tab sex_ident_cd

foreach a in CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd everdrug countdrug adrd_dx {
	tab `a'
}

//bivariate 
foreach a in CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd everdrug race_recode sex_ident_cd {
	tab `a' adrd_dx,chi2
}

//table 1 
ttest age_at_end_ref_yr, by(everdrug)
tabulate race_recode everdrug, chi2 col
tabulate sex_ident_cd everdrug, chi2 col
tabulate adrd_dx everdrug,chi2 col

tabulate hypertension everdrug, chi2 col
tabulate diabetes everdrug, chi2 col
tabulate stroke everdrug, chi2 col
tabulate heart everdrug, chi2 col
tabulate depressive everdrug, chi2 col
tabulate tbi everdrug, chi2 col
tabulate smoking everdrug, chi2 col
tabulate psychosis2 everdrug, chi2 col
tabulate rheumatoid_arthritis everdrug, chi2 row

//table 2 

