= V4 Outline MultiLine NoSorting TabWidth=30

H="setup "

global medi "J:\Geriatrics\Litke_CMS\2019\Raw Data"


//Intermediate Data Path
global intpath  "J:\Geriatrics\Litke_CMS\2019\Int Data"

// Final Data Path
global datapath  "J:\Geriatrics\Litke_CMS\2019\Raw Data"

//Log files path
global outpath  "J:\Geriatrics\Litke_CMS\2019\Raw Data\Output\in_progress"


H="List of Phenothiazines generic names"
//After reviewing the FDA approved phenothiazines we tested in C elegans and microglial cells and comparing with what we had worked with, here is the final list of Phenothiazines:

Prochlorperazine -PCPZ

Chlorpromazine - CPZ

Trifluoperazine - TriHyd

Amitriptyline - AmiHyd

Perphenazine – PFZ

Fluphenazine - Flup

Promethazine - ProHyd

Nortriptyline - NorHyd

H="get NDC codes for CPZ"
import sas using "J:\Geriatrics\Litke_CMS\2019\Raw Data\pde_char\pde_file.sas7bdat",clear
rename*,lower

gen ndc=substr(prod_srvc_id, 1, strlen(prod_srvc_id)-2)

//1. Chlorpromazine - CPZ

gen CPZ=ustrpos(gnn, "CHLORPROMAZINE")

tostring CPZ,replace

keep if CPZ=="1"

duplicates report ndc
bysort ndc: keep if _n==1

keep ndc
rename ndc CPZ

export delimited using "J:\Geriatrics\Litke_CMS\2019\Final Data\CPZ\CPZ_newpde.csv",replace

H="get NDC codes for PCPZ"
import sas using "J:\Geriatrics\Litke_CMS\2019\Raw Data\pde_char\pde_file.sas7bdat",clear
rename*,lower

gen ndc=substr(prod_srvc_id, 1, strlen(prod_srvc_id)-2)

//2. Prochlorperazine -PCPZ

gen PCPZ=ustrpos(gnn, "PROCHLORPERAZINE")

tostring PCPZ,replace

keep if PCPZ=="1"

duplicates report ndc
bysort ndc: keep if _n==1

keep ndc
rename ndc PCPZ

export delimited using "J:\Geriatrics\Litke_CMS\2019\Final Data\NDC Part D\PCPZ_newpde.csv",replace

