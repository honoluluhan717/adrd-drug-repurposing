H="table5"
log using "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\tables5 09.05.smcl",replace 

use "${intpath}/new working data08.29.dta",clear 


//create RA med flag 
//everdrug flag 
gen ra_anydrug_flag=.

replace ra_anydrug_flag=0 if rheumatoid_arthritis==0 & everdrug==0
replace ra_anydrug_flag=1 if rheumatoid_arthritis==1 & everdrug==1
replace ra_anydrug_flag=2 if rheumatoid_arthritis==1 & everdrug==0
replace ra_anydrug_flag=3 if rheumatoid_arthritis==0 & everdrug==1

label define ra_anydrug_flag 0 "no RA no drug" 1 "RA+drug" 2 "RA+no drug" 3 "no RA+drug" 
label values ra_anydrug_flag ra_anydrug_flag

tab ra_anydrug_flag,m

//CPZ
gen ra_CPZ_flag=.

replace ra_CPZ_flag=0 if rheumatoid_arthritis==0 & CPZ!=1
replace ra_CPZ_flag=1 if rheumatoid_arthritis==1 & CPZ==1
replace ra_CPZ_flag=2 if rheumatoid_arthritis==1 & CPZ!=1
replace ra_CPZ_flag=3 if rheumatoid_arthritis==0 & CPZ==1

label define ra_CPZ_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_CPZ_flag ra_CPZ_flag

tab ra_CPZ_flag,m

//PCPZ
gen ra_PCPZ_flag=.

replace ra_PCPZ_flag=0 if rheumatoid_arthritis==0 & PCPZ!=1
replace ra_PCPZ_flag=1 if rheumatoid_arthritis==1 & PCPZ==1
replace ra_PCPZ_flag=2 if rheumatoid_arthritis==1 & PCPZ!=1
replace ra_PCPZ_flag=3 if rheumatoid_arthritis==0 & PCPZ==1

label define ra_PCPZ_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_PCPZ_flag ra_PCPZ_flag

tab ra_PCPZ_flag,m


//TRIHYD
gen ra_TRIHYD_flag=.

replace ra_TRIHYD_flag=0 if rheumatoid_arthritis==0 & TriHyd!=1
replace ra_TRIHYD_flag=1 if rheumatoid_arthritis==1 & TriHyd==1
replace ra_TRIHYD_flag=2 if rheumatoid_arthritis==1 & TriHyd!=1
replace ra_TRIHYD_flag=3 if rheumatoid_arthritis==0 & TriHyd==1

label define ra_TRIHYD_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_TRIHYD_flag ra_TRIHYD_flag

tab ra_TRIHYD_flag,m


//AMIHYD
gen ra_AMIHYD_flag=.

replace ra_AMIHYD_flag=0 if rheumatoid_arthritis==0 & AmiHyd!=1
replace ra_AMIHYD_flag=1 if rheumatoid_arthritis==1 & AmiHyd==1
replace ra_AMIHYD_flag=2 if rheumatoid_arthritis==1 & AmiHyd!=1
replace ra_AMIHYD_flag=3 if rheumatoid_arthritis==0 & AmiHyd==1

label define ra_AMIHYD_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_AMIHYD_flag ra_AMIHYD_flag

tab ra_AMIHYD_flag,m


//PFZ
gen ra_PFZ_flag=.

replace ra_PFZ_flag=0 if rheumatoid_arthritis==0 & PFZ!=1
replace ra_PFZ_flag=1 if rheumatoid_arthritis==1 & PFZ==1
replace ra_PFZ_flag=2 if rheumatoid_arthritis==1 & PFZ!=1
replace ra_PFZ_flag=3 if rheumatoid_arthritis==0 & PFZ==1

label define ra_PFZ_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_PFZ_flag ra_PFZ_flag

tab ra_PFZ_flag,m

//FLUP
gen ra_FLUP_flag=.

replace ra_FLUP_flag=0 if rheumatoid_arthritis==0 & Flup!=1
replace ra_FLUP_flag=1 if rheumatoid_arthritis==1 & Flup==1
replace ra_FLUP_flag=2 if rheumatoid_arthritis==1 & Flup!=1
replace ra_FLUP_flag=3 if rheumatoid_arthritis==0 & Flup==1

label define ra_FLUP_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_FLUP_flag ra_FLUP_flag

tab ra_FLUP_flag,m


//PROHYD
gen ra_PROHYD_flag=. 

replace ra_PROHYD_flag=0 if rheumatoid_arthritis==0 & ProHyd!=1
replace ra_PROHYD_flag=1 if rheumatoid_arthritis==1 & ProHyd==1
replace ra_PROHYD_flag=2 if rheumatoid_arthritis==1 & ProHyd!=1
replace ra_PROHYD_flag=3 if rheumatoid_arthritis==0 & ProHyd==1

label define ra_PROHYD_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_PROHYD_flag ra_PROHYD_flag

tab ra_PROHYD_flag,m


//NORHYD
gen ra_NORHYD_flag=.

replace ra_NORHYD_flag=0 if rheumatoid_arthritis==0 & NorHyd!=1
replace ra_NORHYD_flag=1 if rheumatoid_arthritis==1 & NorHyd==1
replace ra_NORHYD_flag=2 if rheumatoid_arthritis==1 & NorHyd!=1
replace ra_NORHYD_flag=3 if rheumatoid_arthritis==0 & NorHyd==1

label define ra_NORHYD_flag 0 "no RA no med" 1 "RA+med" 2 "RA+no med" 3 "no RA+med"
label values ra_NORHYD_flag ra_NORHYD_flag

tab ra_NORHYD_flag,m


//bivariate 
foreach a in ra_anydrug_flag ra_CPZ_flag ra_PCPZ_flag ra_TRIHYD_flag ra_AMIHYD_flag ra_PFZ_flag ra_FLUP_flag ra_PROHYD_flag ra_NORHYD_flag {
	tab `a' adrd_dx,chi2
}

//multivariate 
//model 1 only drugs 
logistic adrd_dx i.ra_anydrug_flag,or
logistic adrd_dx i.ra_CPZ_flag,or
logistic adrd_dx i.ra_PCPZ_flag ,or
logistic adrd_dx i.ra_TRIHYD_flag,or
logistic adrd_dx i.ra_AMIHYD_flag,or
logistic adrd_dx i.ra_PFZ_flag,or
logistic adrd_dx i.ra_FLUP_flag,or
logistic adrd_dx i.ra_PROHYD_flag,or
logistic adrd_dx i.ra_NORHYD_flag,or

//model 2 drug + demographics 
logistic adrd_dx i.ra_anydrug_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_CPZ_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_PCPZ_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_TRIHYD_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_AMIHYD_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_PFZ_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_FLUP_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_PROHYD_flag i.race_recode i.sex_ident_cd,or
logistic adrd_dx i.ra_NORHYD_flag i.race_recode i.sex_ident_cd,or

//model 3 drug + demographics + all comorbidities (no RA) 
logistic adrd_dx i.ra_anydrug_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_CPZ_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_PCPZ_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_TRIHYD_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_AMIHYD_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_PFZ_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_FLUP_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_PROHYD_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or
logistic adrd_dx i.ra_NORHYD_flag i.race_recode i.sex_ident_cd i.stroke i.hypertension i.diabetes i.heart i.depressive i.tbi i.smoking i.psychosis2,or

translate "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\tables5 09.05.smcl" "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\tables5 09.05.pdf"

log close 



H="6 models revision"
log using "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\table 3 with 6 models 09.19.smcl",replace 

use "${intpath}/new working data08.29.dta",clear 

//6 models in Table 3 
foreach a in CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd everdrug{
	//Model 1- Controlling for age 
	logistic adrd_dx age_at_end_ref_yr i.`a',or

	//Model 2- With Demographics (age, sex, race/ethnicity) 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd,or

	//Model 3- With Demographics and behavioral (smoking) risk factors in table 1 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking,or

	//Model 4- With Demographics, and behavioral (smoking), TBI risk factors in table 1 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi,or

	//Model 5- With Demographics, and behavioral (smoking), TBI, cardiometabolic risk factors in table 1 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.stroke i.hypertension i.diabetes i.heart,or

	//Model 6- With Demographics, and behavioral (smoking), TBI, cardiometabolic and psychiatric risk factors in table 1  
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.stroke i.hypertension i.diabetes i.heart 	i.depressive i.psychosis2,or
}

//Table 1 only for White people 
preserve 
keep if race_recode==1
ttest age_at_end_ref_yr, by(everdrug)
tabulate sex_ident_cd everdrug, chi2 col
tabulate adrd_dx everdrug,chi2 col

tabulate hypertension everdrug, chi2 col
tabulate diabetes everdrug, chi2 col
tabulate stroke everdrug, chi2 col
tabulate heart everdrug, chi2 col
tabulate depressive everdrug, chi2 col
tabulate tbi everdrug, chi2 col
tabulate smoking everdrug, chi2 col
tabulate psychosis2 everdrug, chi2 col
tabulate rheumatoid_arthritis everdrug, chi2 row
restore 

//Table 3 only for White people 
preserve 

keep if race_recode==1

foreach a in CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd everdrug{
	//Model 1- Controlling for age 
	logistic adrd_dx age_at_end_ref_yr i.`a',or

	//Model 2- With Demographics (age, sex, race/ethnicity) 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd,or

	//Model 3- With Demographics and behavioral (smoking) risk factors in table 1 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking,or

	//Model 4- With Demographics, and behavioral (smoking), TBI risk factors in table 1 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi,or

	//Model 5- With Demographics, and behavioral (smoking), TBI, cardiometabolic risk factors in table 1 
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.stroke i.hypertension i.diabetes i.heart,or

	//Model 6- With Demographics, and behavioral (smoking), TBI, cardiometabolic and psychiatric risk factors in table 1  
	logistic adrd_dx i.`a' age_at_end_ref_yr i.race_recode i.sex_ident_cd i.smoking i.tbi i.stroke i.hypertension i.diabetes i.heart 	i.depressive i.psychosis2,or
}

restore 

translate "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\table 3 with 6 models 09.19.smcl" "J:\Geriatrics\Litke_CMS\2019\Output\in_progress\table 3 with 6 models 09.19.pdf"

log close 


