	//depressive symptoms 
			replace depressive=1 if inlist(substr(dgns_`i'_cd,1,2),"I4") | inlist(substr(dgns_`i'_cd,1,4),"9921") | inlist(substr(dgns_`i'_cd,1,4),"9923") | inlist(substr(dgns_`i'_cd,1,4),"3492") 
	//tbi 
			replace tbi=1 if inlist(substr(dgns_`i'_cd,1,4), "8020", "8021", "8024", "8025", "8026", "8027", "8028", "8029", "9050") | inlist(substr(dgns_`i'_cd,1,5), "73382", "80050", "80100", "80150", "80220", "80221", "80222", "80223", "80224") | inlist(substr(dgns_`i'_cd,1,5), "80225", "80226", "80227", "80228", "80230", "80231", "80232", "80233", "80234") | inlist(substr(dgns_`i'_cd,1,5), "80235", "80236", "80237", "80238", "80300", "80350", "87363", "V5419", "8500") | inlist(substr(dgns_`i'_cd,1,5), "85011", "85012", "8503", "8504", "85241", "85244", "85246", "85221", "85224")  | inlist(substr(dgns_`i'_cd,1,5), "85226", "85201", "85204", "85206", "9251", "9064")
