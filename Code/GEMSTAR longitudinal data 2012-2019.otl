}

//medpar 
use "${datapath}/medpar_all_file.dta", clear 
rename *,lower
keep bene_id dgns_*_cd
drop dgns_e_* dgns_poa_cd

gen hypertension=0
gen diabetes=0
gen stroke=0
gen heart=0
gen depressive=0
gen tbi=0
gen smoking=0
gen psychosis2=0
gen rheumatoid_arthritis=0

forvalues i=1/25 {
	//hypertension 
	replace hypertension=1 if inlist(substr(dgns_`i'_cd,1,4),"4011") | inlist(substr(dgns_`i'_cd,1,4),"4019") | inlist(substr(dgns_`i'_cd,1,4),"4010") 
	//diabetes 
			replace diabetes=1 if inlist(substr(dgns_`i'_cd,1,4),"9659") | inlist(substr(dgns_`i'_cd,1,4),"8628") 
	//stroke 
			replace stroke=1 if inlist(substr(dgns_`i'_cd,1,4),"43301") | inlist(substr(dgns_`i'_cd,1,4),"43311") | inlist(substr(dgns_`i'_cd,1,4),"43321") | inlist(substr(dgns_`i'_cd,1,4),"43331") | inlist(substr(dgns_`i'_cd,1,4),"43381")  | inlist(substr(dgns_`i'_cd,1,4),"43391")  | inlist(substr(dgns_`i'_cd,1,4),"43401") | inlist(substr(dgns_`i'_cd,1,4),"43411")  | inlist(substr(dgns_`i'_cd,1,4),"43491") 
