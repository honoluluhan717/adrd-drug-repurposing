= V4 Outline MultiLine NoSorting TabWidth=30

H="clean data "

global medi "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/Raw Data"


//Intermediate Data Path
global intpath  "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/2012/Int Data 2012"

// Final Data Path
global datapath  "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/2012/Raw Data 2012"

//Log files path
global outpath  "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/2012/Raw Data 2012/Output/in_progress"


H="import SAS files and create Stata files"
// Define the folder path
local folder "J:\Geriatrics\Litke_CMS\5yr Request\14543\2012\decrypted data 2012\2012 SAS Datasets"

// List of SAS files
local files bcarrier_line hospice_base_claims mbsf_abcd_summary medpar_all_file outpatient_base_claims outpatient_revenue_center pde_file

// Loop through each file
foreach file in `files' {
    // Import SAS file
    import sas "`folder'/`file'.sas7bdat", clear
    
    // Save as Stata .dta file
    save "`folder'/`file'.dta", replace
}


H="get phenothiazines"
use "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/2012/Raw Data 2012/pde_file.dta",clear 
rename*,lower
keep bene_id prod_srvc_id gnn

gen ndc=substr(prod_srvc_id, 1, strlen(prod_srvc_id)-2)

gen CPZ=ustrpos(gnn, "CHLORPROMAZINE")
gen PCPZ=ustrpos(gnn, "PROCHLORPERAZINE")
gen TriHyd=ustrpos(gnn, "TRIFLUOPERAZINE")
gen AmiHyd=ustrpos(gnn, "AMITRIPTYLINE")
recode AmiHyd (14=1)
gen PFZ=ustrpos(gnn, "PERPHENAZINE")
gen Flup=ustrpos(gnn, "FLUPHENAZINE")
gen ProHyd=ustrpos(gnn, "PROMETHAZINE")
gen NorHyd=ustrpos(gnn, "NORTRIPTYLINE")

gen drug_name=.
replace drug_name = 1 if CPZ==1
replace drug_name = 2 if PCPZ==1
replace drug_name = 3 if TriHyd==1
replace drug_name = 4 if AmiHyd==1
replace drug_name = 5 if PFZ==1
replace drug_name = 6 if Flup==1
replace drug_name = 7 if ProHyd==1 
replace drug_name = 8 if NorHyd==1 

drop if drug_name==.
drop gnn prod_srvc_id ndc

duplicates report bene_id drug_name
return list 

foreach x in CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd {
	by bene_id,sort:egen a=max(`x')
    	replace `x'=a
	drop a
}

drop drug_name
duplicates drop

egen ever_phenothiazines=rowmax(CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd)
egen count_phenothiazines=rowtotal(CPZ PCPZ TriHyd AmiHyd PFZ Flup ProHyd NorHyd)

save "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/2012/Int Data 2012/phenothiazines.dta", replace 


H="get anti-inflammatory drugs"
use "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/Raw Data/2012/pde_file.dta",clear 

rename*,lower

//1. NON-SELECTIVE NSAIDS (17 DRUGS) 
gen non_selec_nsaids=ustrpos(gnn, "DICLOFENAC") | ustrpos(gnn, "DIFLUNISAL") | ustrpos(gnn, "ETODOLAC") | ustrpos(gnn, "FENOPROFEN") | ustrpos(gnn, "FLURBIPROFEN") | ustrpos(gnn, "IBUPROFEN") | ustrpos(gnn, "INDOMETHACIN") | ustrpos(gnn, "KETOPROFEN") | ustrpos(gnn, "KETOROLAC") | ustrpos(gnn, "MEFENAMIC ACID") | ustrpos(gnn, "MELOXICAM") | ustrpos(gnn, "NABUMETONE") | ustrpos(gnn, "NAPROXEN") | ustrpos(gnn, "OXAPROZIN") | ustrpos(gnn, "PIROXICAM") | ustrpos(gnn, "SULINDAC") | ustrpos(gnn, "TOLMETIN")

//2. COX-2 SELECTIVE NSAIDS (1 DRUG) 

gen cox2_selec_nsaids=ustrpos(gnn, "CELECOXIB")

//3. CORTICOSTEROIDS: (30 DRUGS) 

gen corticosteroids=0 

local druglist "BUDESONIDE BECLOMETHASONE BETAMETHASONE CELESTONE CUTIVATE DECADRON DELTASONE DEPO-MEDROL DEXAMETHASONE DIPROLENE DIPROSONE FLONASE FLOVENT FLUDROCORTISONE KENALOG MEDROL MEGACE MEGESTROL ACETATE METHYLPREDNISOLONE ORASONE PREDNISOLONE PREDNISONE RHINOCORT SOLU-MEDROL SOLUMEDROL TRIAMCINOLONE ACETONIDE PULMICORT"

foreach drug in `druglist' {
    replace corticosteroids = 1 if ustrpos(gnn, "`drug'") > 0
}

replace corticosteroids = 1 if ustrpos(gnn, "ENTOCORT EC")>0

//4. DISEASE MODIFYING ANTI RHEUMATIC DRUG DMARD (19 DRUGS) 

gen anti_theumatic=0

local druglist1 "SULFASALAZINE MESALAZINE DEUCRAVACITINIB APREMILAST ABATACEPT BIMEKIZUMAB IXEKIZUMAB RITUXIMAB TOCILIZUMAB SARILUMAB ANAKINRA USTEKINUMAB SECUKINUMAB BELIMUMAB LEFLUNOMIDE GUSELKUMAB  RIZANKIZUMAB TILDRAKIZUMAB DUPILUMAB"

foreach drug in `druglist1' {
    replace anti_theumatic = 1 if ustrpos(gnn, "`drug'") > 0
}

//5. TARGETED DMARD (1 DRUG)

gen targeted_dmard=ustrpos(gnn,"TOFACITINIB") | ustrpos(gnn,"ABROCITINIB") | ustrpos(gnn,"BARICITINIB") | ustrpos(gnn,"FILGOTINIB") | ustrpos(gnn,"UPADACITINIB")

//6. OTHER (7 DRUGS) 

gen other_drug=ustrpos(gnn, "CICLOSPORIN") | ustrpos(gnn,"CYCLOSPORIN") | ustrpos(gnn,"AZATHIOPRINE") | ustrpos(gnn,"TACROLIMUS") | ustrpos(gnn, "SIROLIMUS") | ustrpos(gnn, "METHOTREXATE") | ustrpos(gnn, "HYDROXYCHLOROQUINE") 

//7. IFN (3 DRUGS) 

gen inf_drug=ustrpos(gnn,"PEGINTERFERON") | ustrpos(gnn,"INTERFERON BETA") | ustrpos(gnn,"ANIFROLUMAB")


//8. ANT TNF (7 DRUGS) 

gen ant_tnf=ustrpos(gnn, "ADALIMUMAB") | ustrpos(gnn,"CERTOLIZUMAB") | ustrpos(gnn,"ETANERCEPT") | ustrpos(gnn,"GOLIMUMAB") | ustrpos(gnn, "INFLIXIMAB") | ustrpos(gnn,"ANTI INTEGRIN") | ustrpos(gnn, "VEDOLIZUMAB")

//9. overall anti-inflammatory drug list 
gen anti_inflammatory_drug=0

replace anti_inflammatory_drug=1 if non_selec_nsaids==1 | cox2_selec_nsaids==1 | corticosteroids==1 | anti_theumatic==1 | targeted_dmard==1 | other_drug==1 | inf_drug==1 | ant_tnf==1 

tab anti_inflammatory_drug

duplicates drop bene_id,force

save "/sc/cmsdata/drugsAD/Pepper Longitudinal 2012-2016/2012/Int Data 2012/pde_anti_inflammatory_drug.dta",replace



H="get covariates"
//append and merge all medicare data
//carrier
use "${datapath}/bcarrier_claims.dta", clear 
	rename *,lower
	keep bene_id icd_dgns_cd*
	gen hypertension=0
	gen diabetes=0
	gen stroke=0
	gen heart=0
	gen depressive=0
	gen tbi=0
	gen smoking=0
	gen psychosis2=0
	gen rheumatoid_arthritis=0
	

forvalues i=1/12 {
	//hypertension 
	replace hypertension=1 if inlist(substr(icd_dgns_cd`i',1,4),"4011") | inlist(substr(icd_dgns_cd`i',1,4),"4019") | inlist(substr(icd_dgns_cd`i',1,4),"4010") 
	//diabetes 
			replace diabetes=1 if inlist(substr(icd_dgns_cd`i',1,4),"9659") | inlist(substr(icd_dgns_cd`i',1,4),"8628") 
	//stroke 
			replace stroke=1 if inlist(substr(icd_dgns_cd`i',1,4),"43301") | inlist(substr(icd_dgns_cd`i',1,4),"43311") | inlist(substr(icd_dgns_cd`i',1,4),"43321") | inlist(substr(icd_dgns_cd`i',1,4),"43331") | inlist(substr(icd_dgns_cd`i',1,4),"43381")  | inlist(substr(icd_dgns_cd`i',1,4),"43391")  | inlist(substr(icd_dgns_cd`i',1,4),"43401") | inlist(substr(icd_dgns_cd`i',1,4),"43411")  | inlist(substr(icd_dgns_cd`i',1,4),"43491") 
	//heart 
			replace heart=1 if inlist(substr(icd_dgns_cd`i',1,4),"412") | inlist(substr(icd_dgns_cd`i',1,4),"4111") | inlist(substr(icd_dgns_cd`i',1,4),"4139")  | inlist(substr(icd_dgns_cd`i',1,4),"4142") | inlist(substr(icd_dgns_cd`i',1,4),"4144") | inlist(substr(icd_dgns_cd`i',1,4),"4148") | inlist(substr(icd_dgns_cd`i',1,4),"4292") | inlist(substr(icd_dgns_cd`i',1,5),"41401") | inlist(substr(icd_dgns_cd`i',1,5),"41402")  | inlist(substr(icd_dgns_cd`i',1,5),"41403") | inlist(substr(icd_dgns_cd`i',1,5),"41404") | inlist(substr(icd_dgns_cd`i',1,5),"41405")  | inlist(substr(icd_dgns_cd`i',1,5),"41406")  | inlist(substr(icd_dgns_cd`i',1,5),"41407")  | inlist(substr(icd_dgns_cd`i',1,5),"41410")  | inlist(substr(icd_dgns_cd`i',1,5),"41411") | inlist(substr(icd_dgns_cd`i',1,5),"41412") | inlist(substr(icd_dgns_cd`i',1,5),"41419") | inlist(substr(icd_dgns_cd`i',1,5),"40291") | inlist(substr(icd_dgns_cd`i',1,5),"40201") | inlist(substr(icd_dgns_cd`i',1,5),"40211") | inlist(substr(icd_dgns_cd`i',1,5),"40200") | inlist(substr(icd_dgns_cd`i',1,5),"40210") | inlist(substr(icd_dgns_cd`i',1,5),"40290")
	//depressive symptoms 
			replace depressive=1 if inlist(substr(icd_dgns_cd`i',1,2),"I4") | inlist(substr(icd_dgns_cd`i',1,4),"9921") | inlist(substr(icd_dgns_cd`i',1,4),"9923") | inlist(substr(icd_dgns_cd`i',1,4),"3492") 
	//tbi 
			replace tbi=1 if inlist(substr(icd_dgns_cd`i',1,4), "8020", "8021", "8024", "8025", "8026", "8027", "8028", "8029", "9050") | inlist(substr(icd_dgns_cd`i',1,5), "73382", "80050", "80100", "80150", "80220", "80221", "80222", "80223", "80224") | inlist(substr(icd_dgns_cd`i',1,5), "80225", "80226", "80227", "80228", "80230", "80231", "80232", "80233", "80234") | inlist(substr(icd_dgns_cd`i',1,5), "80235", "80236", "80237", "80238", "80300", "80350", "87363", "V5419", "8500") | inlist(substr(icd_dgns_cd`i',1,5), "85011", "85012", "8503", "8504", "85241", "85244", "85246", "85221", "85224")  | inlist(substr(icd_dgns_cd`i',1,5), "85226", "85201", "85204", "85206", "9251", "9064")
	//smoking 
			replace smoking=1 if inlist(substr(icd_dgns_cd`i',1,4),"3179") | inlist(substr(icd_dgns_cd`i',1,4),"8915")
	//psychosis2
			replace psychosis2=1 if inlist(substr(icd_dgns_cd`i',1,4),"9301", "9309", "9302", "29410", "29411", "29600", "29601") | inlist(substr(icd_dgns_cd`i',1,4),"29602", "29603", "29604", "29605", "29606", "29681")
	//rheumatoid arthritis
			replace rheumatoid_arthritis = 1 if inlist(substr(icd_dgns_cd`i',1,4),"41481", "7142", "3596", "7140", "3571", "7142", "71489", "7149")
}

keep bene_id hypertension diabetes stroke heart depressive tbi smoking psychosis2 rheumatoid_arthritis
save "${intpath}/comorbidities_carrier.dta",replace


//hospice, outpatient 
foreach x in hospice outpatient {
	use "${datapath}/`x'_base_claims.dta", clear 
	
	rename *,lower
	keep bene_id icd_dgns_cd*
	gen hypertension=0
	gen diabetes=0
	gen stroke=0
	gen heart=0
	gen depressive=0
	gen tbi=0
	gen smoking=0
	gen psychosis2=0
